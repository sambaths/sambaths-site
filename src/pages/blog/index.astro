---
export const prerender = true;

import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags || []))].sort();
---

<BaseLayout title="Blog" description="Articles on data science, ML engineering, and building things that work — by Sambath S." url="/blog">
  <div class="container blog-archive">
    <h1 class="blog-archive__heading">Blog</h1>
    <p class="blog-archive__subtitle">Thoughts on AI strategy, data science, and building things that matter.</p>

    {
      allTags.length > 0 && (
        <div class="blog-archive__tags">
          <span class="tag-filter-label">Filter:</span>
          {allTags.map(tag => (
            <a href={`/blog/tags/${tag}`} class="tag tag--link">{tag}</a>
          ))}
        </div>
      )
    }

    <div class="blog-archive__list">
      {sortedPosts.map(post => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-archive {
    max-width: 40rem;
  }

  .blog-archive__heading {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .blog-archive__subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .blog-archive__tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tag-filter-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--color-card-bg);
    color: var(--color-accent);
    border-radius: 0.25rem;
  }

  .tag--link {
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag--link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .blog-archive__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>
