---
import SimpleLayout from '../layouts/SimpleLayout.astro';
---

<SimpleLayout title="CV" description="Experience, skills, and background of Sambath S — AI strategy, data science, and engineering." url="/cv">
  <p class="cv__updated">Last updated: February 2025</p>

  <a href="/cv.pdf" class="btn btn--primary cv__download" download>Download PDF</a>

  <section>
    <h2>Experience</h2>

    <div class="cv-item">
      <h3>AI Strategy Consultant</h3>
      <p class="cv-item__meta">Freelance · 2024 — Present</p>
      <ul>
        <li>Design and deploy AI solutions for clients end-to-end — from the first discovery call to production</li>
        <li>Lead technical discovery and feasibility assessments so teams know what's worth building</li>
        <li>Build data pipelines and ML infrastructure that actually work in production</li>
      </ul>
    </div>

    <div class="cv-item">
      <h3>Senior Data Scientist</h3>
      <p class="cv-item__meta">Prior role</p>
      <ul>
        <li>Built and shipped machine learning models that handled real-world traffic, not just lab accuracy</li>
        <li>Worked across teams to turn vague data ideas into actionable strategies</li>
        <li>Mentored junior data scientists and engineers — and learned as much as I taught</li>
      </ul>
    </div>
  </section>

  <section>
    <h2>Skills</h2>

    <div class="skills-group">
      <div class="skills-group__item">
        <h4>Languages</h4>
        <p>Python, TypeScript, SQL, Bash</p>
      </div>
      <div class="skills-group__item">
        <h4>Frameworks & Tools</h4>
        <p>PyTorch, FastAPI, Astro, React, Git, Docker</p>
      </div>
      <div class="skills-group__item">
        <h4>Cloud & Infrastructure</h4>
        <p>AWS, GCP, Netlify, CI/CD, Docker Compose</p>
      </div>
      <div class="skills-group__item">
        <h4>Strategy</h4>
        <p>AI/ML Strategy, Technical Discovery, Solution Architecture, Team Leadership</p>
      </div>
    </div>
  </section>


</SimpleLayout>

<style>
  .cv__updated {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .cv__download {
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: 0.375rem;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn--primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  section {
    margin-bottom: 2.5rem;
  }

  section h2 {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.25rem;
  }

  .cv-item {
    margin-bottom: 1.5rem;
  }

  .cv-item h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .cv-item__meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .cv-item ul {
    padding-left: 1.25rem;
  }

  .cv-item li {
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
  }

  .skills-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .skills-group__item {
    padding: 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
  }

  .skills-group__item h4 {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  .skills-group__item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .skills-group {
      grid-template-columns: 1fr;
    }
  }
</style>
