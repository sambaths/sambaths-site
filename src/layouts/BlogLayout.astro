---
import BaseLayout from './BaseLayout.astro';
import { readingTime } from '../lib/reading-time';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, date, description, image, tags } = post.data;

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .map(p => ({
    post: p,
    overlap: tags ? tags.filter(t => p.data.tags?.includes(t)).length : 0,
  }))
  .filter(p => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.post.data.date.valueOf() - a.post.data.date.valueOf())
  .slice(0, 3);

const postUrl = `${Astro.url.origin}/blog/${post.slug}/`;
const shareText = encodeURIComponent(title);
const shareUrl = encodeURIComponent(postUrl);
---

<BaseLayout
  title={title}
  description={description || ''}
  image={image}
  url={`/blog/${post.slug}/`}
  type="article"
  publishedTime={date.toISOString()}
  tags={tags}
>
  <nav class="container blog-post__breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">/</span>
    <a href="/blog">Blog</a>
    <span class="breadcrumb__sep">/</span>
    <span class="breadcrumb__current">{title}</span>
  </nav>

  <article class="container blog-post">
    <header class="blog-post__header">
      <p class="blog-post__date">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {readingTime(post.body)} min read</p>
      <h1 class="blog-post__title">{title}</h1>
      {
        tags && tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )
      }
    </header>
    <div class="blog-post__content">
      <Content />
    </div>
  </article>

  <div class="container blog-post__share">
    <p class="blog-post__share-label">Share this post</p>
    <div class="blog-post__share-buttons">
      <a href={`https://twitter.com/intent/tweet?text=${shareText}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on X">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        <span>X</span>
      </a>
      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on LinkedIn">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        <span>LinkedIn</span>
      </a>
      <button class="share-btn share-btn--copy" data-copy-url={postUrl} aria-label="Copy link">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7.24 2h9.52c1.14 0 1.94 0 2.56.05.6.05.93.15 1.2.33.36.24.64.52.88.88.18.27.28.6.33 1.2.05.62.05 1.42.05 2.56v9.52c0 1.14 0 1.94-.05 2.56-.05.6-.15.93-.33 1.2-.24.36-.52.64-.88.88-.27.18-.6.28-1.2.33-.62.05-1.42.05-2.56.05H7.24c-1.14 0-1.94 0-2.56-.05-.6-.05-.93-.15-1.2-.33-.36-.24-.64-.52-.88-.88-.18-.27-.28-.6-.33-1.2C2 19.7 2 18.9 2 17.76V8.24c0-1.14 0-1.94.05-2.56.05-.6.15-.93.33-1.2.24-.36.52-.64.88-.88.27-.18.6-.28 1.2-.33C5.3 3 6.1 3 7.24 3m0-1c-1.16 0-2.02 0-2.7.06-.73.07-1.23.22-1.67.5-.45.3-.82.66-1.11 1.11-.28.44-.43.94-.5 1.67C1 5.28 1 6.14 1 7.3v9.4c0 1.16 0 2.02.06 2.7.07.73.22 1.23.5 1.67.3.45.66.82 1.11 1.11.44.28.94.43 1.67.5.68.06 1.54.06 2.7.06h9.52c1.16 0 2.02 0 2.7-.06.73-.07 1.23-.22 1.67-.5.45-.3.82-.66 1.11-1.11.28-.44.43-.94.5-1.67.06-.68.06-1.54.06-2.7V7.3c0-1.16 0-2.02-.06-2.7-.07-.73-.22-1.23-.5-1.67-.3-.45-.66-.82-1.11-1.11-.44-.28-.94-.43-1.67-.5C18.72 2 17.86 2 16.7 2z"/><path d="M15.75 9.75c.41 0 .75.34.75.75v4.5c0 .41-.34.75-.75.75h-6c-.41 0-.75-.34-.75-.75v-6c0-.41.34-.75.75-.75h4.5zm-2.03-1.5H10.5c-.93 0-1.69 0-2.27.06-.6.06-1.09.2-1.5.5-.32.23-.58.52-.75.86-.21.43-.24.95-.24 1.58v4c0 .63.03 1.15.24 1.58.17.34.43.63.75.86.41.3.9.44 1.5.5.58.06 1.34.06 2.27.06h4c.93 0 1.69 0 2.27-.06.6-.06 1.09-.2 1.5-.5.32-.23.58-.52.75-.86.21-.43.24-.95.24-1.58v-1.5c0-.41-.34-.75-.75-.75s-.75.34-.75.75v1.5c0 .5-.01.84-.04 1.1-.02.25-.07.36-.1.4-.07.1-.17.18-.3.25-.12.07-.31.13-.6.17-.3.04-.67.05-1.21.05h-4c-.54 0-.91-.01-1.21-.05-.29-.04-.48-.1-.6-.17-.13-.07-.23-.15-.3-.25-.03-.04-.08-.15-.1-.4-.03-.26-.04-.6-.04-1.1v-4c0-.5.01-.84.04-1.1.02-.25.07-.36.1-.4.07-.1.17-.18.3-.25.12-.07.31-.13.6-.17.25-.03.57-.05 1-.05h2.72c.41 0 .75-.34.75-.75s-.34-.75-.75-.75"/></svg>
        <span>Copy</span>
      </button>
    </div>
  </div>

  {
    relatedPosts.length > 0 && (
      <div class="container blog-post__related">
        <h2 class="blog-post__related-title">Related Posts</h2>
        <div class="blog-post__related-grid">
          {relatedPosts.map(({ post: related }) => (
            <a href={`/blog/${related.slug}/`} class="related-card">
              <h3 class="related-card__title">{related.data.title}</h3>
              <p class="related-card__meta">
                {related.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                {' · '}
                {readingTime(related.body)} min read
              </p>
              {related.data.description && <p class="related-card__excerpt">{related.data.description}</p>}
            </a>
          ))}
        </div>
      </div>
    )
  }

  <script>
    document.querySelectorAll('.share-btn--copy').forEach(btn => {
      btn.addEventListener('click', async () => {
        const url = btn.getAttribute('data-copy-url');
        if (url) {
          await navigator.clipboard.writeText(url);
          const span = btn.querySelector('span');
          const original = span.textContent;
          span.textContent = 'Copied!';
          setTimeout(() => { span.textContent = original; }, 2000);
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .blog-post__breadcrumb {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .blog-post__breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .blog-post__breadcrumb a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .breadcrumb__sep {
    color: var(--color-border);
  }

  .breadcrumb__current {
    color: var(--color-text);
  }

  .blog-post__header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .blog-post__date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .blog-post__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .blog-post__tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--color-card-bg);
    color: var(--color-accent);
    border-radius: 0.25rem;
  }

  .blog-post__content {
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .blog-post__content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content :global(p) {
    margin-bottom: 1.25rem;
  }

  .blog-post__content :global(pre) {
    background: var(--color-code-bg);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .blog-post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .blog-post__content :global(:not(pre) > code) {
    background: var(--color-code-bg);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
  }

  .blog-post__content :global(ul), .blog-post__content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-post__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--color-text-muted);
  }

  .blog-post__content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .blog-post__content :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem auto;
  }

  .blog-post__content :global(a) {
    text-decoration: underline;
  }

  .blog-post__share {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .blog-post__share-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .blog-post__share-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-card-bg);
    color: var(--color-text);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    font-family: inherit;
  }

  .share-btn:hover {
    border-color: var(--color-accent);
    background: var(--color-code-bg);
  }

  .blog-post__related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .blog-post__related-title {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .blog-post__related-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .related-card {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .related-card:hover {
    border-color: var(--color-accent);
  }

  .related-card__title {
    font-size: 1rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .related-card__meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .related-card__excerpt {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
