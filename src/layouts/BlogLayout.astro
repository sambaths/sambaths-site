---
import BaseLayout from './BaseLayout.astro';
import { readingTime } from '../lib/reading-time';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, date, description, image, tags } = post.data;
---

<BaseLayout
  title={title}
  description={description || ''}
  image={image}
  url={`/blog/${post.slug}/`}
  type="article"
  publishedTime={date.toISOString()}
  tags={tags}
>
  <article class="container blog-post">
    <header class="blog-post__header">
      <p class="blog-post__date">{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {readingTime(post.body)} min read</p>
      <h1 class="blog-post__title">{title}</h1>
      {
        tags && tags.length > 0 && (
          <div class="blog-post__tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )
      }
    </header>
    <div class="blog-post__content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post__header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .blog-post__date {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .blog-post__title {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .blog-post__tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    background: var(--color-card-bg);
    color: var(--color-accent);
    border-radius: 0.25rem;
  }

  .blog-post__content {
    max-width: 42rem;
    margin: 0 auto;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .blog-post__content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post__content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post__content :global(p) {
    margin-bottom: 1.25rem;
  }

  .blog-post__content :global(pre) {
    background: var(--color-code-bg);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .blog-post__content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .blog-post__content :global(:not(pre) > code) {
    background: var(--color-code-bg);
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
  }

  .blog-post__content :global(ul), .blog-post__content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-post__content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--color-text-muted);
  }

  .blog-post__content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .blog-post__content :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem auto;
  }

  .blog-post__content :global(a) {
    text-decoration: underline;
  }
</style>
