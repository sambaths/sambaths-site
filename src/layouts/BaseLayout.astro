---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import SEO from '../components/SEO.astro';
import Analytics from '@vercel/analytics/astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
}

const { title, description, image, url, type, publishedTime, tags } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Sambath S" href="/feed.xml" />
    <script is:inline>(function(){var t=localStorage.getItem('theme');t&&document.documentElement.setAttribute('data-theme',t)})()</script>
    <SEO title={title} description={description} image={image} url={url} type={type} publishedTime={publishedTime} tags={tags} />
  </head>
  <body>
    <header class="masthead">
      <div class="container masthead__inner">
        <a href="/" class="masthead__brand">Sambath S</a>
        <nav class="masthead__nav" aria-label="Main navigation">
          <a href="/" class={currentPath === '/' ? 'nav-link nav-link--active' : 'nav-link'}>Home</a>
          <a href="/blog" class={currentPath.startsWith('/blog') ? 'nav-link nav-link--active' : 'nav-link'}>Blog</a>
          <a href="/start-here" class={currentPath === '/start-here' ? 'nav-link nav-link--active' : 'nav-link'}>Start Here</a>
          <a href="/cv" class={currentPath === '/cv' ? 'nav-link nav-link--active' : 'nav-link'}>CV</a>
          <a href="/contact" class={currentPath === '/contact' ? 'nav-link nav-link--active' : 'nav-link'}>Contact</a>
        </nav>
        <ThemeToggle />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Analytics />

    <footer class="footer">
      <div class="container footer__inner">
        <div class="footer__social">
          <a href="https://linkedin.com/in/sambaths" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/sambaths" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="mailto:sambaths1@outlook.com" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
          <a href="/feed.xml" aria-label="RSS Feed">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
          </a>
        </div>
        <p class="footer__copy">&copy; {new Date().getFullYear()} Sambath S. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .masthead {
    display: none;
  }

  .footer {
    display: none;
  }

  main {
    padding: 0 !important;
    min-height: 100vh !important;
  }

  .masthead__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .masthead__brand {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
    white-space: nowrap;
  }

  .masthead__brand:hover {
    color: var(--color-accent);
  }

  .masthead__nav {
    display: flex;
    gap: 1.25rem;
    margin-right: auto;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--color-text);
  }

  main {
    min-height: calc(100vh - 12rem);
    padding: 3rem 0;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer__social a {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
  }

  .footer__social a:hover {
    color: var(--color-accent);
  }

  .footer__copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .masthead__inner {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .masthead__nav {
      order: 1;
      width: 100%;
      gap: 0.75rem;
    }
  }
</style>
