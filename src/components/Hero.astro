---

<section class="hero">
  <div class="container hero__inner">
    <h1 class="hero__name">Sambath S</h1>
    <p class="hero__tagline">I build AI systems. Strategy through code, whiteboard through production.</p>
    <p class="hero__subtitle">
      Production ML, data pipelines, and the glue that holds them together.
    </p>
    <div class="hero__cta">
      <a href="/cv" class="btn btn--primary">View CV</a>
      <a href="/contact" class="btn btn--secondary">Get in Touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hero__name {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .hero__tagline {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-accent);
    max-width: 36rem;
  }

  .hero__subtitle {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 32rem;
    line-height: 1.6;
  }

  .hero__cta {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    border-radius: 0.375rem;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn--primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .btn--secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 3rem 0 2rem;
    }

    .hero__name {
      font-size: 2rem;
    }

    .hero__tagline {
      font-size: 1.05rem;
    }

    .hero__cta {
      flex-direction: column;
    }
  }
</style>
