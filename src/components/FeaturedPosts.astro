<section class="featured">
  <div class="container">
    <h2 class="featured__heading">Latest Posts</h2>
    <p class="featured__subtitle">Thoughts on AI strategy, data science, and building things that matter.</p>
    <div class="featured__grid">
      <p class="featured__empty">Visit the <a href="/blog">blog</a> for my latest posts on AI strategy, data science, and engineering.</p>
    </div>
  </div>
</section>

<style>
  .featured {
    padding: 3rem 0;
  }

  .featured__heading {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .featured__subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 2rem;
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1.5rem;
  }

  .featured__empty {
    grid-column: 1 / -1;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    text-align: center;
    padding: 2rem;
    border: 1px dashed var(--color-border);
    border-radius: 0.5rem;
  }
</style>
