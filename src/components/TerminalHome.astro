---
import ParticleCanvas from './ParticleCanvas.astro';
import PostCard from './PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section class="proto-b" id="proto-b-root">
  <ParticleCanvas />

  <div class="container proto-b__inner">
    <aside class="proto-b__sidebar" aria-label="Quick info">
      <div class="proto-b__card proto-b__nav-card">
        <p class="proto-b__prompt">
          <span class="proto-b__prompt-symbol">❯</span>
          <span class="proto-b__cmd-text">cd ~ &amp;&amp; ls -la</span>
        </p>
        <nav class="proto-b__nav">
          <a href="/" class="proto-b__nav-link">~/home</a>
          <a href="/blog" class="proto-b__nav-link">~/blog</a>
        </nav>
        <button class="proto-b__theme-btn" id="proto-b-theme" aria-label="Toggle theme">
          <span class="proto-b__theme-label" id="proto-b-theme-label">theme: dark</span>
        </button>
      </div>

      <div class="proto-b__card">
        <p class="proto-b__prompt">
          <span class="proto-b__prompt-symbol">❯</span>
          <span class="proto-b__cmd-text">whoami</span>
        </p>
        <pre class="proto-b__block proto-b__whoami">
Name:    Sambath S
Title:   AI Engineer
Focus:   ML, Agentic AI, Statistics
        </pre>
      </div>

      <div class="proto-b__card">
        <p class="proto-b__prompt">
          <span class="proto-b__prompt-symbol">❯</span>
          <span class="proto-b__cmd-text">ls ./expertise/</span>
        </p>
        <div class="proto-b__badge-grid">
          <span class="proto-b__badge">Agentic</span>
          <span class="proto-b__badge">AI</span>
          <span class="proto-b__badge">Machine Learning</span>
          <span class="proto-b__badge">Data Science</span>
          <span class="proto-b__badge">Systems</span>
        </div>
      </div>

      <div class="proto-b__card">
        <p class="proto-b__prompt">
          <span class="proto-b__prompt-symbol">❯</span>
          <span class="proto-b__cmd-text">cat ./contact</span>
        </p>
        <div class="proto-b__contact">
          <span class="proto-b__contact-line"><span class="proto-b__contact-key">email</span>   <a href="mailto:sambaths1@outlook.com">sambaths1@outlook.com</a></span>
          <span class="proto-b__contact-line"><span class="proto-b__contact-key">github</span>  <a href="https://github.com/sambaths" target="_blank">github.com/sambaths</a></span>
          <span class="proto-b__contact-line"><span class="proto-b__contact-key">linkedin</span> <a href="https://linkedin.com/in/sambaths" target="_blank">in/sambaths</a></span>
          <span class="proto-b__contact-line"><span class="proto-b__contact-key">x</span>       <a href="https://x.com/sambath__s" target="_blank">@sambath__s</a></span>
        </div>
      </div>

    </aside>

    <script is:inline async src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form="01ac2b16-b9eb-4411-a482-2430e8a4a8de"></script>

    <main class="proto-b__main">
      <p class="proto-b__big-prompt">
        <span class="proto-b__prompt-symbol">❯</span>
        <span class="proto-b__cmd-text">echo "figuring_out.py"</span>
      </p>

      <h1 class="proto-b__headline">
        Why it works <span class="proto-b__accent">matters more</span> than that it works.
      </h1>

      <hr class="proto-b__hr" />

      <p class="proto-b__prompt">
        <span class="proto-b__prompt-symbol">❯</span>
        <span class="proto-b__cmd-text">cat ./latest-posts</span>
      </p>

      {latestPosts.map(post => <PostCard post={post} />)}

      <div class="proto-b__more">
        <span class="proto-b__prompt-symbol">❯</span>
        <a href="/blog">./view-all-posts</a>
      </div>

      <hr class="proto-b__hr" />

      <div class="proto-b__cta">
        <form class="proto-b__cv-form" id="cv-form">
          <span class="proto-b__prompt-symbol">❯</span>
          <span class="proto-b__cmd-text">request-cv </span>
          <input type="email" id="cv-email" placeholder="your@email.com" required class="proto-b__cv-input" />
          <button type="submit" class="proto-b__btn proto-b__btn--primary">./send</button>
        </form>
        <p class="proto-b__cv-success" id="cv-success" hidden>✓ Link sent — check your inbox</p>
      </div>
    </main>
  </div>
</section>

<script>
  import { cycleTheme, applyTheme, initTheme } from '../lib/theme';

  (function() {
    var themeBtn = document.getElementById('proto-b-theme');
    var themeLabel = document.getElementById('proto-b-theme-label');
    var themeIcons = { dark: '☾ ', light: '☀ ', contrast: '◐ ' };

    function updateThemeUI(theme) {
      if (themeLabel) themeLabel.textContent = 'theme: ' + (themeIcons[theme] || '') + theme;
    }

    initTheme();

    if (themeBtn) {
      themeBtn.addEventListener('click', function() {
        var current = document.documentElement.getAttribute('data-theme') || 'dark';
        var next = cycleTheme(current);
        applyTheme(next);
        updateThemeUI(next);
      });

      var initial = document.documentElement.getAttribute('data-theme') || 'dark';
      updateThemeUI(initial);
    }

    var cvForm = document.getElementById('cv-form');
    var cvSuccess = document.getElementById('cv-success');
    if (cvForm) {
      cvForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        var email = document.getElementById('cv-email').value;
        var btn = cvForm.querySelector('button');
        btn.textContent = './sending';
        btn.disabled = true;
        try {
          var res = await fetch('/api/request-cv', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          if (!res.ok) throw new Error();
          cvForm.style.display = 'none';
          cvSuccess.hidden = false;
        } catch {
          btn.textContent = './send';
          btn.disabled = false;
          btn.textContent = '× error';
          setTimeout(function() { btn.textContent = './send'; }, 3000);
        }
      });
    }
  })();
</script>

<style>
  .proto-b {
    position: relative;
    font-family: var(--font-mono);
    padding: 2rem 0 4rem;
    overflow: hidden;
    min-height: 100vh;
    background: var(--color-bg);
    color: var(--color-text);
    transition: background 0.3s, color 0.3s;
  }

  .proto-b__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 24rem 1fr;
    gap: 3rem;
    align-items: start;
    max-width: 64rem;
  }

  .proto-b__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 2rem;
  }

  .proto-b__card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 1rem 0.25rem;
    transition: background 0.3s, border-color 0.3s;
  }

  .proto-b__nav-card {
    padding-bottom: 0.75rem;
  }

  .proto-b__prompt {
    margin-bottom: 0.5rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.82rem;
    display: flex;
    align-items: center;
    gap: 0;
    transition: color 0.3s;
  }

  .proto-b__big-prompt {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    color: var(--color-accent);
    display: flex;
    align-items: center;
    gap: 0;
    transition: color 0.3s;
  }

  .proto-b__prompt-symbol {
    color: var(--color-accent);
    font-weight: 700;
    margin-right: 0.5rem;
    flex-shrink: 0;
    transition: color 0.3s;
  }

  .proto-b__cmd-text {
    overflow: hidden;
    white-space: nowrap;
    display: inline-block;
    max-width: 0;
    animation: protoBType 2.5s steps(40, end) forwards;
    animation-delay: 0.2s;
    transition: color 0.3s;
  }

  .proto-b__card:nth-child(2) .proto-b__cmd-text { animation-delay: 0.7s; }
  .proto-b__card:nth-child(3) .proto-b__cmd-text { animation-delay: 1.2s; }
  .proto-b__card:nth-child(4) .proto-b__cmd-text { animation-delay: 1.7s; }

  @keyframes protoBType {
    from { max-width: 0; border-right: 2px solid var(--color-accent); }
    90% { border-right: 2px solid var(--color-accent); }
    to { max-width: 40ch; border-right: 2px solid transparent; }
  }

  .proto-b__nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.75rem;
  }

  .proto-b__nav-link {
    display: block;
    padding: 0.3rem 0.5rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: 0.25rem;
    transition: color 0.15s, background 0.15s;
  }

  .proto-b__nav-link:hover {
    color: var(--color-accent);
    background: var(--color-code-bg);
  }

  .proto-b__theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 0.5rem;
    font-size: 0.82rem;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    color: var(--color-accent);
    cursor: pointer;
    font-family: var(--font-mono);
    transition: border-color 0.2s, color 0.2s, background 0.3s;
    width: 100%;
  }

  .proto-b__theme-btn:hover {
    border-color: var(--color-accent);
    background: var(--color-card-bg);
  }

  .proto-b__block {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-all;
    color: var(--color-text);
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .proto-b__whoami {
    border-left: 2px solid var(--color-accent);
    transition: border-color 0.3s;
  }

  .proto-b__contact {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    line-height: 1.8;
    color: var(--color-text);
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .proto-b__contact-line {
    display: block;
  }

  .proto-b__contact-key {
    display: inline-block;
    width: 5rem;
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .proto-b__contact a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .proto-b__contact a:hover {
    color: var(--color-accent);
  }

  .proto-b__badge-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  @keyframes protoBFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  @keyframes protoBGlow {
    0%, 100% { box-shadow: 0 0 6px rgba(0,0,0,0.1); }
    50% { box-shadow: 0 0 14px rgba(0,0,0,0.2); }
  }

  .proto-b__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 500;
    border-radius: 2rem;
    background: var(--color-code-bg);
    color: var(--color-accent);
    border: 1px solid var(--color-border);
    cursor: default;
    transition: border-color 0.2s, color 0.2s, background 0.3s, border-color 0.3s;
    animation: protoBFloat 3s ease-in-out infinite;
  }

  .proto-b__badge:nth-child(1) { animation-delay: 0s; color: #a78bfa; border-color: rgba(167, 139, 250, 0.3); }
  .proto-b__badge:nth-child(2) { animation-delay: 0.3s; color: #22d3ee; border-color: rgba(34, 211, 238, 0.3); }
  .proto-b__badge:nth-child(3) { animation-delay: 0.6s; color: #34d399; border-color: rgba(52, 211, 153, 0.3); }
  .proto-b__badge:nth-child(4) { animation-delay: 0.9s; color: #f59e0b; border-color: rgba(245, 158, 11, 0.3); }
  .proto-b__badge:nth-child(5) { animation-delay: 1.2s; color: #f472b6; border-color: rgba(244, 114, 182, 0.3); }

  .proto-b__badge:hover {
    animation: protoBGlow 1s ease-in-out infinite;
    border-color: currentColor;
  }

  .proto-b__headline {
    font-family: var(--font-sans);
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    transition: color 0.3s;
  }

  .proto-b__accent {
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .proto-b__lead {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    transition: color 0.3s;
  }

  .proto-b__hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.5rem 0;
    transition: border-color 0.3s;
  }

  .proto-b__post {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 0.75rem;
    padding: 1rem 0.75rem;
    margin: 0 -0.75rem;
    border-bottom: 1px solid var(--color-border);
    border-radius: 0.375rem;
    transition: background 0.2s, padding-left 0.2s, border-color 0.3s;
  }

  .proto-b__post:hover {
    background: var(--color-card-bg);
    padding-left: 1.25rem;
  }

  .proto-b__post:last-of-type { border-bottom: none; }

  .proto-b__post-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    transition: color 0.3s;
  }

  .proto-b__date { display: block; }

  .proto-b__type {
    font-size: 0.75rem;
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .proto-b__post-title {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .proto-b__post-title a {
    color: var(--color-text);
    transition: color 0.2s;
  }

  .proto-b__post-title a:hover {
    color: var(--color-accent);
  }

  .proto-b__post-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    line-height: 1.6;
    transition: color 0.3s;
  }

  .proto-b__more {
    font-size: 0.85rem;
    margin-top: 0.75rem;
  }

  .proto-b__more a {
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .proto-b__more a:hover {
    color: var(--color-accent-hover);
  }

  .proto-b__cta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .proto-b__cv-form {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: nowrap;
  }

  .proto-b__cv-input {
    background: transparent;
    border: none;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    margin-left: 0.75rem;
    padding: 0;
    outline: none;
    flex: 1;
    min-width: 0;
    caret-color: var(--color-accent);
  }

  .proto-b__cv-input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .proto-b__cv-form .proto-b__btn {
    margin-left: 1.5rem;
    flex-shrink: 0;
  }

  .proto-b__cv-success {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin: 0;
  }

  .proto-b__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 0.375rem;
    transition: all 0.2s, background 0.3s, border-color 0.3s, color 0.3s;
    text-decoration: none;
    font-family: var(--font-mono);
  }

  .proto-b__btn--primary {
    background: var(--color-accent);
    color: #0c0c10;
    border: 1px solid var(--color-accent);
  }

  .proto-b__btn--primary:hover {
    background: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    box-shadow: 0 0 14px rgba(0, 0, 0, 0.25);
    color: #0c0c10;
  }

  .proto-b__btn--secondary {
    border: 1.5px solid var(--color-border);
    color: var(--color-text);
  }

  .proto-b__btn--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .proto-b__btn--link {
    padding: 0.625rem 0.5rem;
    color: var(--color-text-muted);
  }

  .proto-b__btn--link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .proto-b { padding: 1.5rem 0 3rem; }
    .proto-b__inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .proto-b__sidebar { position: static; }
    .proto-b__headline { font-size: 1.75rem; }
    .proto-b__post { grid-template-columns: 1fr; gap: 0.25rem; }
    .proto-b__post-meta { display: flex; gap: 0.5rem; }
    .proto-b__cta { flex-direction: column; }
  }
</style>
